---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects" href="projects">
  {
    projects.map(({ name, summary, image, linkSource, linkDemo }, index) => {
      const top = 98 + index * 40;
      // Cek apakah ini proyek Resto Cloud untuk menampilkan video

      return (
        <div
          style={`top: ${top}px;`}
          class="project-card sticky mb-12 rounded-2xl border border-neutral/20 bg-black overflow-hidden"
        >
          <div class="bg-difu relative z-[1] grid h-[580px] w-full grid-rows-2 rounded-2xl bg-[#050505]/90 before:absolute before:inset-0 before:z-[-1] before:rounded-2xl before:bg-[url(/raja.png)] before:bg-[length:128px] before:bg-repeat before:opacity-[5%] before:content-[''] sm:grid-cols-2 sm:grid-rows-1 md:h-96">
            
            <div class="px-6 pt-12">
              <h3 class="mb-5 font-serif text-3xl font-medium text-primary tracking-tight">
                {name}
              </h3>
              <p class="text-base text-neutral leading-relaxed">{summary}</p>
              
              <div class="flex gap-6 pt-10">
                <a
                  href={linkSource}
                  target="_blank"
                  class="text-white flex items-center gap-2 hover:text-primary transition-colors hover:underline decoration-primary"
                >
                  Source <img src="/external.svg" class="w-4 h-4" alt="" />
                </a>
                {linkDemo && (
                  <a
                    href={linkDemo}
                    target="_blank"
                    class="text-primary font-bold flex items-center gap-2 hover:brightness-125 transition-all"
                  >
                    Live Demo <span class="text-xs">▶</span>
                  </a>
                )}
              </div>
            </div>

            <div class="flex items-end justify-end overflow-hidden group">
                <Image
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                  src={image}
                  alt={name}
                  width="736"
                  height="483"
                />
            </div>
          </div>
        </div>
      );
    })
  } 
</Section>